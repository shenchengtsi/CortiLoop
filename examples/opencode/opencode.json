{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "cortiloop": {
      "type": "local",
      "command": ["python", "-m", "cortiloop.adapters.mcp_server"],
      "environment": {
        "CORTILOOP_DB_PATH": "~/.config/opencode/cortiloop.db",
        "CORTILOOP_NAMESPACE": "opencode",
        "CORTILOOP_LLM_PROVIDER": "local"
      },
      "enabled": false
    }
  },

  "permission": {
    "memory_*": "allow"
  }
}
